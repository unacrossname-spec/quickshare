{
  "$schema": "https://raw.githubusercontent.com/nicegram/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "QuickShare",
  "version": "0.2.0",
  "identifier": "com.quickshare.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "QuickShare",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
